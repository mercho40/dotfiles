theme = Catppuccin Mocha
font-size= 16
shell-integration = zsh
macos-option-as-alt = true
mouse-hide-while-typing = true
confirm-close-surface=false
macos-titlebar-style = tabs
macos-window-shadow= false
window-save-state = always

# vim-style split navigation
keybind = super+h=goto_split:left
keybind = super+j=goto_split:down
keybind = super+k=goto_split:up
keybind = super+l=goto_split:right

# quake-style dropdown terminal (global — works even when ghostty isn't focused)
keybind = global:cmd+grave_accent=toggle_quick_terminal

# jump between shell prompts in scrollback (uses shell-integration)
keybind = super+up=jump_to_prompt:-1
keybind = super+down=jump_to_prompt:1
